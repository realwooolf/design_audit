{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 120
    },
    "api/verify.js": {
      "maxDuration": 60
    },
    "api/figma-export.js": {
      "maxDuration": 30
    },
    "api/match-pairs.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
